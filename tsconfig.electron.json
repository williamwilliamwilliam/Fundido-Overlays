{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "downlevelIteration": true,
    "outDir": "dist/electron",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@capture/*": ["src/capture/*"],
      "@state/*": ["src/state/*"],
      "@overlay/*": ["src/overlay/*"],
      "@persistence/*": ["src/persistence/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "ui", "src/**/*.spec.ts"]
}
